{
  "name": "asklens",
  "displayName": "AskLens for Claude Code",
  "description": "Ask selected text in Claude Code with full session context.",
  "version": "0.0.7",
  "publisher": "asklens",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/QingsongTan/ask-anytime-vscode"
  },
  "homepage": "https://github.com/QingsongTan/ask-anytime-vscode#readme",
  "bugs": {
    "url": "https://github.com/QingsongTan/ask-anytime-vscode/issues"
  },
  "engines": { "vscode": "^1.95.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "asklens.explainSelection", "title": "AskLens: 解释选中文本" },
      { "command": "asklens.uninstallHook", "title": "AskLens: 移除 SessionStart hook" },
      { "command": "asklens.exportKnowledge", "title": "AskLens: 导出知识文档", "icon": "$(export)" },
      { "command": "asklens.switchModel", "title": "AskLens: 切换 Provider / 模型", "icon": "$(symbol-misc)" },
      { "command": "asklens.setApiKey", "title": "AskLens: 设置 API key" },
      { "command": "asklens.clearApiKey", "title": "AskLens: 清除 API key" }
    ],
    "keybindings": [
      { "command": "asklens.explainSelection", "key": "ctrl+enter", "mac": "cmd+enter" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "asklens", "title": "AskLens", "icon": "$(comment-discussion)" }
      ]
    },
    "views": {
      "asklens": [
        { "id": "asklens.annotations", "name": "批注", "type": "webview" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "asklens.switchModel", "when": "view == asklens.annotations", "group": "navigation@1" },
        { "command": "asklens.exportKnowledge", "when": "view == asklens.annotations", "group": "navigation@2" }
      ]
    },
    "configuration": {
      "title": "AskLens",
      "properties": {
        "asklens.provider": { "type": "string", "enum": ["claude", "openai", "ollama", "deepseek", "qwen", "kimi", "glm", "doubao", "hunyuan", "minimax", "yi", "step", "ernie"], "default": "claude" },
        "asklens.model": { "type": "string", "default": "claude-opus-4-8" },
        "asklens.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama 服务的 HTTP 地址, 远端部署时改这里"
        },
        "asklens.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API 基地址, 走中转/镜像时改这里"
        },
        "asklens.obsidianVaultPath": {
          "type": "string",
          "default": "",
          "description": "Obsidian Vault 根目录路径，导出知识文档后自动写入原子笔记。留空则每次导出时弹窗选择。"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsc -p test/integration/tsconfig.json && node dist-tests/test/integration/run.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
