{
  "name": "ask-anytime",
  "displayName": "Ask Anytime",
  "description": "在 Claude Code 回答里选中文字, 一键获得结合会话上下文的 AI 解释",
  "version": "0.0.5",
  "publisher": "tanqs",
  "engines": { "vscode": "^1.95.0" },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "ask-anytime.explainSelection", "title": "Ask Anytime: 解释选中文本" },
      { "command": "ask-anytime.uninstallHook", "title": "Ask Anytime: 移除 SessionStart hook" },
      { "command": "ask-anytime.exportKnowledge", "title": "Ask Anytime: 导出知识文档", "icon": "$(export)" },
      { "command": "ask-anytime.switchModel", "title": "Ask Anytime: 切换 Provider / 模型", "icon": "$(symbol-misc)" },
      { "command": "ask-anytime.setApiKey", "title": "Ask Anytime: 设置 API key" },
      { "command": "ask-anytime.clearApiKey", "title": "Ask Anytime: 清除 API key" }
    ],
    "keybindings": [
      { "command": "ask-anytime.explainSelection", "key": "ctrl+shift+a", "mac": "cmd+shift+a" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "ask-anytime", "title": "Ask Anytime", "icon": "$(comment-discussion)" }
      ]
    },
    "views": {
      "ask-anytime": [
        { "id": "ask-anytime.annotations", "name": "批注", "type": "webview" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "ask-anytime.switchModel", "when": "view == ask-anytime.annotations", "group": "navigation@1" },
        { "command": "ask-anytime.exportKnowledge", "when": "view == ask-anytime.annotations", "group": "navigation@2" }
      ]
    },
    "configuration": {
      "title": "Ask Anytime",
      "properties": {
        "ask-anytime.provider": { "type": "string", "enum": ["claude", "openai", "ollama", "deepseek", "qwen", "kimi", "glm", "doubao", "hunyuan", "minimax", "yi", "step", "ernie"], "default": "claude" },
        "ask-anytime.model": { "type": "string", "default": "claude-opus-4-7" },
        "ask-anytime.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama 服务的 HTTP 地址, 远端部署时改这里"
        },
        "ask-anytime.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API 基地址, 走中转/镜像时改这里"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsc -p test/integration/tsconfig.json && node dist-tests/test/integration/run.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
